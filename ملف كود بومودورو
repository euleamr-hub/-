<script>
(function () {
    'use strict';

    var root = document.querySelector('.opt-widget');
    if (!root || root.dataset.optInitialized === 'true') { return; } 
    root.dataset.optInitialized = 'true';

    var $ = function (id) { return root.querySelector('#' + id); };

    // ==========================================
    // ⚙️ نظام تخزين محلي ذكي لتجنب انهيار الـ Iframes والـ Private Browsing
    // ==========================================
    var safeStorage = {
        getItem: function (key) {
            try { return localStorage.getItem(key); } catch (e) { return null; }
        },
        setItem: function (key, val) {
            try { localStorage.setItem(key, val); return true; } catch (e) { return false; }
        }
    };

    var soundUrls = {
        alarm: "https://cdn.jsdelivr.net/gh/euleamr-hub/-/%D9%85%D9%86%D8%A8%D9%87.mp3",       
        defeat: "https://cdn.jsdelivr.net/gh/euleamr-hub/-/%D9%87%D8%B2%D9%8A%D9%85%D8%A9.mp3",   
        birds: "https://cdn.jsdelivr.net/gh/euleamr-hub/-/Bird%20Sounds%20Spectacular%20Morning%20Bird%20Sound.mp3",
        rain: "https://cdn.jsdelivr.net/gh/euleamr-hub/-/rain%20sound.mp3",
        noise: "https://cdn.jsdelivr.net/gh/euleamr-hub/-/White%20Noise.mp3"
    };

    var soundAlarm = new Audio(soundUrls.alarm);
    var soundDefeat = new Audio(soundUrls.defeat);

    var ambientSounds = {
        birds: new Audio(soundUrls.birds),
        rain: new Audio(soundUrls.rain),
        noise: new Audio(soundUrls.noise)
    };

    for (var key in ambientSounds) {
        ambientSounds[key].loop = true;
    }

    var activeAmbientKey = null;      
    var savedAmbientKeyForResume = null; 

    function playAmbient(key) {
        for (var k in ambientSounds) {
            if (k !== key || activeAmbientKey === key) {
                ambientSounds[k].pause();
                $('opt-btn-' + k).classList.remove('opt-active');
            }
        }

        if (activeAmbientKey === key) {
            activeAmbientKey = null;
        } else {
            ambientSounds[key].play().catch(function(e) {
                console.log("المتصفح يطلب تفاعل المستخدم أولاً لتشغيل الصوت");
            });
            $('opt-btn-' + key).classList.add('opt-active');
            activeAmbientKey = key;
        }
    }

    function stopAllAmbient() {
        for (var k in ambientSounds) {
            ambientSounds[k].pause();
            $('opt-btn-' + k).classList.remove('opt-active');
        }
        activeAmbientKey = null;
    }

    var timer = null, isRunning = false, isWorkMode = true, currentCycle = 1, totalCycles = 4, timeLeft = 25 * 60;
    var totalFocusMinutes = parseInt(safeStorage.getItem('opt_totalFocusMinutes')) || 0;
    var towerFloorsCount = parseInt(safeStorage.getItem('opt_towerFloorsCount')) || 0;

    var unlockedWorker2 = safeStorage.getItem('opt_unlockedWorker2') === 'true';
    var unlockedWorker3 = safeStorage.getItem('opt_unlockedWorker3') === 'true';

    var timeString = $('opt-time-string'), timerStatus = $('opt-timer-status');
    var btnStart = $('opt-btn-start');
    var btnEnd = $('opt-btn-end');
    var charBubble = $('opt-char-bubble'), towerFloorsEl = $('opt-tower-floors');
    var statHeight = $('opt-stat-height'), statHours = $('opt-stat-hours');
    var statPopulation = $('opt-stat-population'), currentCycleView = $('opt-current-cycle-view');
    var inputCycles = $('opt-input-cycles'), inputWork = $('opt-input-work'), inputBreak = $('opt-input-break');

    var pendingTransition = null; 

    function resetTimerValues() {
        if (isRunning) { return; } 
        totalCycles = parseInt(inputCycles.value) || 4;
        var minutes = isWorkMode ? (parseInt(inputWork.value) || 25) : (parseInt(inputBreak.value) || 5);
        timeLeft = minutes * 60;
        updateTimerView();
        currentCycleView.value = currentCycle + ' / ' + totalCycles;
    }

    function updateTimerView() {
        var mins = Math.floor(timeLeft / 60).toString().padStart(2, '0');
        var secs = (timeLeft % 60).toString().padStart(2, '0');
        timeString.innerText = mins + ':' + secs;
    }

    function updateStatsDisplays() {
        var currentHeight = towerFloorsCount * 3;
        statHeight.innerText = currentHeight + ' م';
        statHours.innerText = totalFocusMinutes + ' د';
        statPopulation.innerText = (towerFloorsCount * 2) + ' سكان';
        currentCycleView.value = currentCycle + ' / ' + totalCycles;

        $('opt-worker-2').style.display = currentHeight >= 100 ? 'block' : 'none';
        $('opt-worker-3').style.display = currentHeight >= 1000 ? 'block' : 'none';

        toggleRoadmapItem('opt-road-style-2', currentHeight >= 30);
        toggleRoadmapItem('opt-road-style-3', currentHeight >= 90);
        toggleRoadmapItem('opt-road-worker-2', currentHeight >= 100);
        toggleRoadmapItem('opt-road-worker-3', currentHeight >= 1000);

        if (currentHeight >= 100 && !unlockedWorker2) {
            triggerCelebration("🥽 انضمام المهندس صابر!", "نجحت في الوصول لـ 100 متر! انضم إليك المهندس 'صابر'، ليوجه البناء بكفاءة أعلى!");
            unlockedWorker2 = true; safeStorage.setItem('opt_unlockedWorker2', 'true');
        }
        if (currentHeight >= 1000 && !unlockedWorker3) {
            triggerCelebration("👔 انضمام كبير المهندسين حكيم!", "إنجاز أسطوري! وصلت إلى 1000 متر! انضم إليكم كبير المهندسين 'حكيم' ليدير تشييد ناطحات السحاب!");
            unlockedWorker3 = true; safeStorage.setItem('opt_unlockedWorker3', 'true');
        }
    }

    function toggleRoadmapItem(id, isDone) {
        var el = $(id);
        if (isDone) { el.classList.add('opt-done'); } else { el.classList.remove('opt-done'); }
    }

    function renderTower() {
        towerFloorsEl.innerHTML = '';
        for (var i = 0; i < towerFloorsCount; i++) {
            var floor = document.createElement('div'); floor.className = 'opt-floor';
            if (i * 3 >= 90) { floor.classList.add('opt-style-future'); }
            else if (i * 3 >= 30) { floor.classList.add('opt-style-modern'); }

            var win1 = document.createElement('div'); win1.className = 'opt-window';
            var av1 = document.createElement('div'); av1.className = 'opt-resident-avatar'; win1.appendChild(av1);
            var win2 = document.createElement('div'); win2.className = 'opt-window';
            var av2 = document.createElement('div'); av2.className = 'opt-resident-avatar'; win2.appendChild(av2);
            floor.appendChild(win1); floor.appendChild(win2); towerFloorsEl.appendChild(floor);
        }
    }

    function arrangeWorkersPosition(state) {
        var currentHeight = towerFloorsCount * 3;
        var workers = [$('opt-worker-1'), $('opt-worker-2'), $('opt-worker-3')];
        var ladders = [$('opt-ladder-1'), $('opt-ladder-2'), $('opt-ladder-3')];
        var targetHeight = Math.min(towerFloorsCount * 40, 100);

        workers.forEach(function (w) { w.className = 'opt-character ' + state; });

        if (state === 'opt-working') {
            ladders[0].style.display = 'block'; ladders[0].style.height = targetHeight + 'px';
            if (currentHeight >= 100) { ladders[1].style.display = 'block'; ladders[1].style.height = targetHeight + 'px'; }
            if (currentHeight >= 1000) { ladders[2].style.display = 'block'; ladders[2].style.height = targetHeight + 'px'; }
            workers.forEach(function (w) { w.style.bottom = (targetHeight + 6) + 'px'; });
            charBubble.innerText = "نحن نعمل بجد فوق السلالم لنبني أعلى جدار في البرج!";
            setTimeout(function () { towerFloorsEl.scrollTop = towerFloorsEl.scrollHeight; }, 150);
        } else if (state === 'opt-dizzy') {
            ladders.forEach(function (l) { l.style.height = '0px'; setTimeout(function () { l.style.display = 'none'; }, 400); });
            workers.forEach(function (w) { w.style.bottom = '6px'; });
            charBubble.innerText = "آااخ! سقطنا على الأرض ودارت النجوم حول رؤوسنا! 😵‍💫";
            setTimeout(function () { towerFloorsEl.scrollTop = 0; }, 150);
        } else if (state === 'opt-resting') {
            ladders[0].style.display = 'block'; ladders[0].style.height = targetHeight + 'px';
            if (currentHeight >= 100) { ladders[1].style.display = 'block'; ladders[1].style.height = targetHeight + 'px'; }
            if (currentHeight >= 1000) { ladders[2].style.display = 'block'; ladders[2].style.height = targetHeight + 'px'; }
            workers.forEach(function (w) { w.style.bottom = (targetHeight + 10) + 'px'; });
            charBubble.innerText = "فترة الاستراحة الهادئة فوق قمة البرج السكني..";
        } else {
            ladders.forEach(function (l) { l.style.height = '0px'; l.style.display = 'none'; });
            workers.forEach(function (w) { w.style.bottom = '6px'; });
            charBubble.innerText = "الورشة بانتظار بدء الجلسة لنبدأ العمل.";
        }
    }

    function createSparkEffect() {
        if (!isRunning || !isWorkMode) { return; }
        var currentHeight = towerFloorsCount * 3;
        var activeWorkers = [$('opt-worker-1')];
        if (currentHeight >= 100) { activeWorkers.push($('opt-worker-2')); }
        if (currentHeight >= 1000) { activeWorkers.push($('opt-worker-3')); }

        var stage = root.querySelector('.opt-stage');
        activeWorkers.forEach(function (worker) {
            var spark = document.createElement('div'); spark.className = 'opt-spark';
            var charRect = worker.getBoundingClientRect(); var stageRect = stage.getBoundingClientRect();
            spark.style.left = (charRect.left - stageRect.left + 10) + 'px';
            spark.style.bottom = (stageRect.bottom - charRect.top - 18) + 'px';
            spark.style.animation = 'opt-sparkExplode 0.3s ease-out forwards';
            stage.appendChild(spark);
            setTimeout(function () { spark.remove(); }, 300);
        });
    }

    function step() {
        if (!isRunning) { return; }

        if (timeLeft > 0) {
            timeLeft--; updateTimerView();
        } else {
            clearInterval(timer); timer = null; isRunning = false;
            soundAlarm.play().catch(function(e){});
            timeString.classList.remove('opt-pulsing');

            if (isWorkMode) {
                savedAmbientKeyForResume = activeAmbientKey;
                stopAllAmbient();

                totalFocusMinutes += parseInt(inputWork.value) || 25;
                towerFloorsCount++;
                safeStorage.setItem('opt_totalFocusMinutes', totalFocusMinutes);
                safeStorage.setItem('opt_towerFloorsCount', towerFloorsCount);
                renderTower();
                updateStatsDisplays();

                if (currentCycle >= totalCycles) {
                    triggerCelebration("🏆 نهاية النوبة بنجاح!", "عمل أسطوري! أكملت جميع جولات الدراسة وبنيت مجتمعاً رائعاً!");
                    resetTimer(); return;
                }

                showConfirmPopup(
                    "🎉 جولة دراسة ممتازة!",
                    "انتهت الجولة وحان وقت الاستراحة الهادئة. هل تريد تشغيل وقت الراحة والبدء الآن؟ ☕",
                    "☕",
                    function() { 
                        isWorkMode = false;
                        timerStatus.innerText = "فترة الراحة ☕";
                        arrangeWorkersPosition('opt-resting');
                        var minutes = parseInt(inputBreak.value) || 5;
                        timeLeft = minutes * 60;
                        updateTimerView();
                        isRunning = true;
                        timeString.classList.add('opt-pulsing');
                        btnStart.innerText = "⏸️ إيقاف مؤقت";
                        timer = setInterval(step, 1000);
                    }
                );

            } else {
                showConfirmPopup(
                    "⏳ انتهت الاستراحة!",
                    "العمال مستعدون للعودة للبناء والدراسة. هل أنت جاهز لبدء دورة تركيز جديدة؟ 📚",
                    "📚",
                    function() { 
                        isWorkMode = true;
                        currentCycle++;
                        timerStatus.innerText = "فترة الدراسة 📚";
                        arrangeWorkersPosition('opt-working');
                        
                        if (savedAmbientKeyForResume) {
                            playAmbient(savedAmbientKeyForResume);
                            savedAmbientKeyForResume = null;
                        }

                        var minutes = parseInt(inputWork.value) || 25;
                        timeLeft = minutes * 60;
                        updateTimerView();
                        isRunning = true;
                        timeString.classList.add('opt-pulsing');
                        btnStart.innerText = "⏸️ إيقاف مؤقت";
                        timer = setInterval(step, 1000);
                    }
                );
            }
            btnStart.innerText = "🚀 ابدأ التركيز";
        }
    }

    function showConfirmPopup(title, desc, emoji, onYesCallback) {
        $('opt-confirm-title').innerText = title;
        $('opt-confirm-desc').innerText = desc;
        $('opt-confirm-emoji').innerText = emoji;
        $('opt-confirm-box').classList.add('opt-active');
        pendingTransition = onYesCallback;
    }

    $('opt-confirm-yes').addEventListener('click', function() {
        $('opt-confirm-box').classList.remove('opt-active');
        if (pendingTransition) {
            pendingTransition();
            pendingTransition = null;
        }
    });

    $('opt-confirm-no').addEventListener('click', function() {
        $('opt-confirm-box').classList.remove('opt-active');
        pendingTransition = null;
        resetTimer();
    });

    function triggerCelebration(title, desc) {
        $('opt-celeb-title').innerText = title;
        $('opt-celeb-desc').innerText = desc;
        $('opt-celebration-box').classList.add('opt-active');
    }
    function closeCelebration() { $('opt-celebration-box').classList.remove('opt-active'); }

    function resetTimer() {
        isRunning = false; clearInterval(timer); timer = null;
        isWorkMode = true; currentCycle = 1;
        btnStart.innerText = "🚀 ابدأ التركيز"; timerStatus.innerText = "جاهز للمهمة";
        timeString.classList.remove('opt-pulsing');
        arrangeWorkersPosition('opt-idle'); resetTimerValues(); updateStatsDisplays(); renderTower();
    }

    $('opt-btn-birds').addEventListener('click', function () { playAmbient('birds'); });
    $('opt-btn-rain').addEventListener('click', function () { playAmbient('rain'); });
    $('opt-btn-noise').addEventListener('click', function () { playAmbient('noise'); });

    $('opt-celeb-close').addEventListener('click', closeCelebration);
    [inputCycles, inputWork, inputBreak].forEach(function (el) { el.addEventListener('input', resetTimerValues); });

    btnStart.addEventListener('click', function () {
        if (isRunning) {
            isRunning = false; btnStart.innerText = "🚀 ابدأ التركيز";
            clearInterval(timer); timer = null;
            timeString.classList.remove('opt-pulsing');
            
            soundDefeat.play().catch(function(e){});
            arrangeWorkersPosition('opt-dizzy');
        } else {
            isRunning = true; btnStart.innerText = "⏸️ إيقاف مؤقت";
            timeString.classList.add('opt-pulsing');
            arrangeWorkersPosition(isWorkMode ? 'opt-working' : 'opt-resting');
            if (!timer) { timer = setInterval(step, 1000); }
        }
    });

    btnEnd.addEventListener('click', function () {
        clearInterval(timer); timer = null; isRunning = false;
        stopAllAmbient();
        resetTimer();
    });

    renderTower();
    updateStatsDisplays();
    resetTimerValues();
    setInterval(createSparkEffect, 450);
})();
</script>
