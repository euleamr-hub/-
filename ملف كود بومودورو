    .opt-celebration-popup { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.8); background: var(--white); border: 4px solid var(--gold); padding: 18px; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.3); z-index: 1000; text-align: center; max-width: 320px; width: 90%; display: none; opacity: 0; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); color: var(--text-dark); }
