    .opt-dizzy-stars { position: absolute; top: -10px; left: 3px; font-size: 10px; display: none; animation: opt-spin 1s linear infinite; }
    .opt-character.opt-working .opt-char-arm-tool { display: block; animation: opt-proHammerHit 0.15s linear infinite alternate; }
